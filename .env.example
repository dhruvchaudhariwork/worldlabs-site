# Copy to .env.local and fill in. .env.local is gitignored — never commit it.

# Supabase → Project Settings → Data API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase → Project Settings → API Keys → service_role
# FULL ACCESS. Server-side only. Never expose to the browser, never commit.
SUPABASE_SERVICE_ROLE_KEY=

# Gates the /admin review dashboard. Pick something long.
ADMIN_PASSWORD=

# Random string used to sign admin session cookies.
# Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=
